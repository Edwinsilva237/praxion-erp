# ─── App ───────────────────────────────────────────────────────────────────
# 'development' (local), 'production' (Render), 'test' (jest).
# En production se activa SSL al pool de PG, fail-fast si JWT_SECRET es débil,
# y la whitelist de CORS solo permite APP_URL + sus subdominios.
NODE_ENV=development
PORT=3000

# ─── Database ──────────────────────────────────────────────────────────────
# En Render, una sola variable DATABASE_URL trae todo. Para que funcione tanto
# local como en Render, las migrations y el pool leen DB_HOST/PORT/etc. Si vas
# a usar Render, partir el DATABASE_URL en estas variables (en el panel se
# pueden poner mapeadas).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_base
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── Email / SMTP ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=tu_cuenta@gmail.com
EMAIL_FROM_NAME=SaaS Base

# ─── App URL (frontend público) ────────────────────────────────────────────
# Usada para: (1) links en emails, (2) whitelist de CORS, (3) construir URLs
# de password reset / confirmación. En producción debe ser el dominio del
# frontend con https. Subdominios *.tu-dominio.com se permiten automáticamente.
APP_URL=http://localhost:3000

# ─── Uploads ───────────────────────────────────────────────────────────────
# UPLOAD_DIR es fallback en dev: cuando R2_BUCKET está vacío los archivos se
# escriben aquí. En producción configura R2 abajo y este dir queda sin uso.
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE_MB=20

# ─── Object Storage (Cloudflare R2, S3-compatible) ─────────────────────────
# Deja R2_BUCKET vacío para usar disco local (modo dev). Para activar R2:
#   1) crea bucket en dash.cloudflare.com → R2
#   2) genera API token con permisos Object Read/Write sobre ese bucket
#   3) endpoint resuelve a https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# 'auto' funciona para R2. Para AWS S3 usar p.ej. 'us-east-1'.
R2_REGION=auto
# TTL de signed URL (segundos). 300s = 5min — suficiente para que el browser
# siga el 302 redirect; no queremos URLs que se puedan compartir.
R2_SIGNED_URL_TTL=300

# ─── Facturapi (timbrado CFDI) ─────────────────────────────────────────────
# Estas keys son fallback. Cada tenant DEBERÍA configurar sus propias keys
# en tenant_fiscal_profiles.facturapi_api_key_live/_test. Cuando no las
# tenga, el sistema cae a estas variables globales (útil para sandbox compartido
# en desarrollo).
FACTURAPI_KEY=
FACTURAPI_KEY_TEST=
# User Secret Key — solo necesaria para crear organizations y subir CSDs
# (dashboard Facturapi → Configuración → API → Llave Secreta de Usuario).
FACTURAPI_USER_KEY=

# ─── Stripe (pagos y suscripciones) ────────────────────────────────────────
# Dejar STRIPE_SECRET_KEY vacío para deshabilitar pagos (el sistema funciona
# como hoy sin cobros). Para activar:
#   1) dashboard.stripe.com → Developers → API keys → Reveal test key
#   2) En el dashboard crea 3 products (Free, Pro, Enterprise) con sus prices
#      y pega los price IDs en la tabla plans (sql update o seed)
#   3) En Developers → Webhooks crea un endpoint apuntando a
#      https://tu-dominio.com/api/billing/webhook y selecciona los eventos:
#      checkout.session.completed, customer.subscription.{updated,deleted},
#      invoice.payment_failed. Copia el "Signing secret" en STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=14
STRIPE_GRACE_DAYS=7
# APP_PUBLIC_URL: URL del frontend para que Stripe Checkout redirija al
# usuario después de pagar (success_url / cancel_url).
APP_PUBLIC_URL=http://localhost:5173

# ─── Cola de tareas en segundo plano (BullMQ + Redis) ──────────────────────
# Dejar REDIS_URL vacío para que correos y timbrado corran sincrónicos como
# antes (modo dev sin Redis). Para activar la cola:
#   1) Regístrate gratis en upstash.com
#   2) Crea una base "Redis" en la región más cercana
#   3) Copia el "Redis URL" (incluye contraseña) — formato: rediss://default:xxx@xxx.upstash.io:6379
REDIS_URL=
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_MS=1000
QUEUE_KEEP_COMPLETED_SEC=86400
QUEUE_KEEP_FAILED_SEC=604800

# ─── Sentry (error tracking) ───────────────────────────────────────────────
# Dejar vacío para deshabilitar. Crea un proyecto Node.js en sentry.io y pega
# aquí el DSN. Los errores 5xx se reportarán con tags tenant_id y user_id.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
# Identificador del release/deploy (ej. commit SHA o tag de versión)
SENTRY_RELEASE=
