VITE_APP_NAME=SaaS ERP
# Dejar vacío en dev — Vite proxy maneja /api → localhost:3000.
# En producción setear a la URL completa del backend, p.ej.
# VITE_API_URL=https://api.praxionops.com/api
VITE_API_URL=

# ─── Sentry (error tracking) ───────────────────────────────────────────────
# Vacío = deshabilitado. Crear un proyecto React en sentry.io y pegar el DSN.
VITE_SENTRY_DSN=
VITE_SENTRY_ENV=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
