# ── Node ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Variables de entorno (NUNCA subir secretos) ─────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production
.env.production.local

# ── Builds ──────────────────────────────────────────────────────────────
dist/
build/
coverage/
.nyc_output/

# ── Editor / OS ─────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
*.swp

# ── Logs ────────────────────────────────────────────────────────────────
*.log
logs/

# ── Uploads locales y archivos de prueba ────────────────────────────────
saas-base/uploads/
saas-base/pdf/
saas-base/xml/
saas-base/*.pdf
saas-base/*.xml
saas-base/*.zip

# ── Scripts ad-hoc de mantenimiento / debug ─────────────────────────────
# Estos son scripts que armamos para arreglar datos puntuales — no son
# parte del producto y no deben llegar al repo.
saas-base/check-*.js
saas-base/check_*.js
saas-base/debug_*.js
saas-base/diag*.js
saas-base/fix-*.js
saas-base/fix_*.js
saas-base/recalc*.js
saas-base/recalcular-*.js
saas-base/reabrir-*.js
saas-base/nuevo-*.js
saas-base/setup_*.js
saas-base/clear_*.js
saas-base/_PATCH_*.txt

# ── Notas locales (handoffs, contextos viejos) ──────────────────────────
# Solo en raíz y subcarpetas que no sean docs/historia/.
HANDOFF*.md
CONTEXT*.md
NOTAS*.txt
DIGITOS*.txt
# Excepción: lo que se conserva como histórico ya migrado al repo.
!docs/historia/HANDOFF*.md
!docs/historia/CONTEXT*.md
!docs/historia/DECISIONS*.md

# ── Sentry CLI ──────────────────────────────────────────────────────────
.sentryclirc

# ── Carpeta de archivos de soporte del usuario (fuera del producto) ─────
files/

# ── Config local de Claude Code ─────────────────────────────────────────
.claude/
